---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import soundTrack from "../assets/audio/sound-track.mp3";

const { title } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '') || '';
---

<html lang="en">
  <head>
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem("theme");
          var d = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (t === "dark" || (!t && d)) document.documentElement.classList.add("dark");
        } catch(e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={base + '/favicon.png'} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-40YPY6TBEG"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-40YPY6TBEG');
    </script>
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <!-- Navigation progress bar -->
    <div id="nprogress" style="position: fixed; top: 0; left: 0; right: 0; height: 2px; z-index: 9999; pointer-events: none; display: none;">
      <div style="height: 100%; background: var(--accent); width: 0;"></div>
    </div>
    <audio id="bg-music" src={soundTrack} loop muted autoplay preload="metadata" data-astro-transition-persist="bg-music"></audio>

    <header class="fixed top-0 left-0 right-0 z-50 border-b border-border" style="background: var(--bg); border-color: var(--border); backdrop-filter: blur(12px);">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href={base + '/'} class="group relative font-body text-sm font-semibold tracking-tight" style="color: var(--text);">
          amrloksha151
          <span class="absolute -bottom-1 left-0 h-[2px] w-0 transition-all duration-300 group-hover:w-full" style="background: var(--accent);"></span>
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6 sm:gap-8">
          <a href={base + '/about'} class="relative text-sm transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            About
          </a>
          <a href={base + '/skills'} class="relative text-sm transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            Skills
          </a>
          <a href={base + '/projects'} class="relative text-sm transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            Projects
          </a>
          <a href={base + '/contact'} class="relative text-sm transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            Contact
          </a>
          <button id="music-toggle" data-astro-transition-persist="music-toggle" class="flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 cursor-pointer" style="border-color: var(--border); color: var(--text-muted);" aria-label="Toggle background music">
            <svg id="music-off-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <line x1="23" y1="9" x2="17" y2="15"/>
              <line x1="17" y1="9" x2="23" y2="15"/>
            </svg>
            <svg id="music-on-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
            </svg>
          </button>
          <button id="theme-toggle" data-astro-transition-persist="theme-toggle" class="flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 cursor-pointer" style="border-color: var(--border); color: var(--text-muted);" aria-label="Toggle theme">
            <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>

        <!-- Mobile controls -->
        <div class="flex md:hidden items-center gap-2">
          <button id="music-toggle-mobile" class="flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 cursor-pointer" style="border-color: var(--border); color: var(--text-muted);" aria-label="Toggle background music">
            <svg id="music-off-icon-mobile" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <line x1="23" y1="9" x2="17" y2="15"/>
              <line x1="17" y1="9" x2="23" y2="15"/>
            </svg>
            <svg id="music-on-icon-mobile" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
            </svg>
          </button>
          <button id="theme-toggle-mobile" class="flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 cursor-pointer" style="border-color: var(--border); color: var(--text-muted);" aria-label="Toggle theme">
            <svg id="sun-icon-mobile" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <svg id="moon-icon-mobile" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <button id="hamburger-btn" class="flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 cursor-pointer" style="border-color: var(--border); color: var(--text-muted);" aria-label="Toggle menu">
            <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="6" x2="20" y2="6"/>
              <line x1="4" y1="12" x2="20" y2="12"/>
              <line x1="4" y1="18" x2="20" y2="18"/>
            </svg>
            <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="md:hidden" style="display: none; border-top: 1px solid var(--border); background: var(--bg); backdrop-filter: blur(12px);">
        <nav class="mx-auto flex max-w-5xl flex-col gap-1 px-6 py-4">
          <a href={base + '/about'} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            About
          </a>
          <a href={base + '/skills'} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            Skills
          </a>
          <a href={base + '/projects'} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            Projects
          </a>
          <a href={base + '/contact'} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors duration-200" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">
            Contact
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 pt-28 pb-20">
      <slot />
    </main>

    <footer class="border-t" style="border-color: var(--border);">
      <div class="mx-auto flex max-w-5xl flex-col items-center gap-3 px-6 py-10 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="12" viewBox="0 0 80 12" fill="none">
          <path d="M2 6 C 10 1, 20 11, 30 6 C 40 1, 50 11, 60 6 C 70 1, 78 10, 78 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4" style="stroke: var(--accent);"/>
        </svg>
        <p class="text-sm" style="color: var(--text-muted);">&copy; {new Date().getFullYear()} Amr Yasser Loksha</p>
        <p class="font-hand text-xs" style="color: var(--text-muted); opacity: 0.6;">ship. break. learn. repeat.</p>
      </div>
    </footer>

    <script>
      function syncTheme() {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = stored === "dark" || (!stored && prefersDark);
        document.documentElement.classList.toggle("dark", isDark);
      }

      function updateIcons() {
        var isDark = document.documentElement.classList.contains("dark");
        var sun = document.getElementById("sun-icon");
        var moon = document.getElementById("moon-icon");
        if (sun && moon) {
          sun.style.display = isDark ? "none" : "";
          moon.style.display = isDark ? "" : "none";
        }
        var sunMob = document.getElementById("sun-icon-mobile");
        var moonMob = document.getElementById("moon-icon-mobile");
        if (sunMob && moonMob) {
          sunMob.style.display = isDark ? "none" : "";
          moonMob.style.display = isDark ? "" : "none";
        }
      }

      function updateMusicIcons() {
        var audio = document.getElementById("bg-music");
        if (!audio) return;
        var muted = audio.muted;
        var off = document.getElementById("music-off-icon");
        var on = document.getElementById("music-on-icon");
        if (off && on) {
          off.style.display = muted ? "" : "none";
          on.style.display = muted ? "none" : "";
        }
        var offMob = document.getElementById("music-off-icon-mobile");
        var onMob = document.getElementById("music-on-icon-mobile");
        if (offMob && onMob) {
          offMob.style.display = muted ? "" : "none";
          onMob.style.display = muted ? "none" : "";
        }
      }

      function setupToggleButtons() {
        var themeBtn = document.getElementById("theme-toggle");
        if (themeBtn && !themeBtn._hasListener) {
          themeBtn._hasListener = true;
          themeBtn.addEventListener("click", function () {
            var nowDark = document.documentElement.classList.toggle("dark");
            localStorage.setItem("theme", nowDark ? "dark" : "light");
            updateIcons();
          });
        }

        var musicBtn = document.getElementById("music-toggle");
        if (musicBtn && !musicBtn._hasListener) {
          musicBtn._hasListener = true;
          musicBtn.addEventListener("click", function () {
            var a = document.getElementById("bg-music");
            var wasMuted = a.muted;
            a.muted = !wasMuted;
            localStorage.setItem("music", wasMuted ? "on" : "off");
            if (wasMuted) a.play();
            updateMusicIcons();
          });
        }

        // Mobile buttons — proxy clicks to desktop buttons
        var themeBtnMob = document.getElementById("theme-toggle-mobile");
        if (themeBtnMob && !themeBtnMob._hasListener) {
          themeBtnMob._hasListener = true;
          themeBtnMob.addEventListener("click", function () {
            var btn = document.getElementById("theme-toggle");
            if (btn) btn.click();
          });
        }

        var musicBtnMob = document.getElementById("music-toggle-mobile");
        if (musicBtnMob && !musicBtnMob._hasListener) {
          musicBtnMob._hasListener = true;
          musicBtnMob.addEventListener("click", function () {
            var btn = document.getElementById("music-toggle");
            if (btn) btn.click();
          });
        }
      }

      function setupHamburgerMenu() {
        var btn = document.getElementById("hamburger-btn");
        if (!btn || btn._hasListener) return;
        btn._hasListener = true;
        btn.addEventListener("click", function () {
          var menu = document.getElementById("mobile-menu");
          var ham = document.getElementById("hamburger-icon");
          var close = document.getElementById("close-icon");
          var open = menu && menu.style.display !== "none";
          if (menu) menu.style.display = open ? "none" : "";
          if (ham) ham.style.display = open ? "" : "none";
          if (close) close.style.display = open ? "none" : "";
        });
      }

      function closeMobileMenu() {
        var menu = document.getElementById("mobile-menu");
        var ham = document.getElementById("hamburger-icon");
        var close = document.getElementById("close-icon");
        if (menu) menu.style.display = "none";
        if (ham) ham.style.display = "";
        if (close) close.style.display = "none";
      }

      function restoreMusic() {
        var audio = document.getElementById("bg-music");
        if (audio && !audio._restored) {
          audio._restored = true;
          if (localStorage.getItem("music") === "on") {
            audio.muted = false;
            audio.play();
          }
        }
        updateMusicIcons();
      }

      // === Runs before DOM swap — override swap to re-apply theme after Astro strips <html> attributes ===
      document.addEventListener("astro:before-swap", (e) => {
        syncTheme();
        closeMobileMenu();
        var originalSwap = e.swap;
        e.swap = function () {
          originalSwap();
          syncTheme();
        };
      });

      // === Close mobile menu on nav link click ===
      document.addEventListener("astro:before-preparation", function () {
        closeMobileMenu();
        var wrap = document.getElementById("nprogress");
        var bar = wrap && wrap.firstElementChild;
        if (!bar) return;
        wrap.style.display = "";
        bar.style.width = "0";
        bar.style.transition = "none";
        requestAnimationFrame(function () {
          bar.style.transition = "width 2s ease";
          bar.style.width = "60%";
        });
      });

      document.addEventListener("astro:after-swap", function () {
        var wrap = document.getElementById("nprogress");
        var bar = wrap && wrap.firstElementChild;
        if (!bar) return;
        bar.style.transition = "width 0.15s ease";
        bar.style.width = "100%";
        setTimeout(function () { wrap.style.display = "none"; bar.style.width = "0"; }, 200);
      });

      // === Close mobile menu on Escape ===
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeMobileMenu();
      });

      // === After full page load ===
      document.addEventListener("astro:page-load", function () {
        syncTheme();
        updateIcons();
        setupToggleButtons();
        setupHamburgerMenu();
        restoreMusic();
      });
    </script>
  </body>
</html>
