---
import Layout from "../layouts/Layout.astro";

const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";
const turnstileSiteKey = "0x4AAAAAAD5FMr1N43RV9apF";
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '') || '';
---

<Layout title="Contact — Amr Yasser Loksha">
  <div class="mx-auto max-w-2xl">
    <div class="flex items-center gap-3">
      <span class="font-hand text-sm" style="color: var(--accent);">Contact</span>
      <span class="h-px flex-1" style="background: var(--border);"></span>
    </div>

    <h1 class="mt-6 text-3xl font-light tracking-tight sm:text-4xl md:text-5xl" style="color: var(--text);">
      Get in touch
    </h1>
    <p class="mt-3 max-w-lg leading-relaxed text-secondary">
      Have a project, a security finding, or just want to say hi? Drop a message and I'll get back to you.
    </p>

    <form id="contact-form" class="mt-10 space-y-6">
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-medium" style="color: var(--text);">Name <span style="color: var(--accent);">*</span></label>
          <input type="text" id="name" name="name" required class="mt-2 block w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200" style="border: 1px solid var(--border); background: var(--surface); color: var(--text);" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium" style="color: var(--text);">Email <span style="color: var(--accent);">*</span></label>
          <input type="email" id="email" name="email" required class="mt-2 block w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200" style="border: 1px solid var(--border); background: var(--surface); color: var(--text);" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="phone" class="block text-sm font-medium" style="color: var(--text);">Phone</label>
          <input type="tel" id="phone" name="phone" class="mt-2 block w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200" style="border: 1px solid var(--border); background: var(--surface); color: var(--text);" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
        </div>
        <div>
          <label for="subject" class="block text-sm font-medium" style="color: var(--text);">Subject <span style="color: var(--accent);">*</span></label>
          <input type="text" id="subject" name="subject" required class="mt-2 block w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200" style="border: 1px solid var(--border); background: var(--surface); color: var(--text);" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium" style="color: var(--text);">Message <span style="color: var(--accent);">*</span></label>
        <textarea id="message" name="message" required rows="6" class="mt-2 block w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200 resize-y" style="border: 1px solid var(--border); background: var(--surface); color: var(--text);" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'"></textarea>
      </div>

      <!-- Turnstile -->
      <div>
        <div
          class="cf-turnstile flex justify-center rounded-xl p-4"
          style="border: 1px solid var(--border); background: var(--surface); min-height: 72px;"
          data-sitekey={turnstileSiteKey}
          data-callback="onTurnstileSuccess"
          data-expired-callback="onTurnstileExpired"
          data-error-callback="onTurnstileError"
        ></div>
        <div id="turnstile-error" class="mt-2 text-xs" style="display: none; color: #E07060;">Please complete the verification.</div>
      </div>

      <button type="submit" id="submit-btn" class="group relative inline-flex items-center gap-2 rounded-full px-8 py-3 text-sm font-medium transition-all duration-300 cursor-pointer" style="border: 1px solid var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); color: var(--accent); opacity: 0.5;" onmouseover="if (!this.disabled) this.style.background='color-mix(in srgb, var(--accent) 20%, transparent)'" onmouseout="if (!this.disabled) this.style.background='color-mix(in srgb, var(--accent) 10%, transparent)'" disabled>
        <span id="btn-text">Send message</span>
        <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4 20-7z"/></svg>
        <svg id="btn-spinner" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;" class="animate-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      </button>

      <div id="status-message" class="text-sm font-medium" style="display: none;"></div>
    </form>

    <div class="mt-16" style="border-top: 1px solid var(--border);">
      <div class="pt-8 flex items-center justify-between">
        <a href={base + '/'} class="group inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 cursor-pointer" style="color: var(--accent);" onmouseover="this.style.color='var(--accent-soft)'" onmouseout="this.style.color='var(--accent)'">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back home
        </a>
        <span class="font-hand text-sm" style="color: var(--text-muted);">say hello</span>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var ts = document.querySelector(".cf-turnstile");
      if (ts) {
        ts.setAttribute("data-theme",
          document.documentElement.classList.contains("dark") ? "dark" : "light");
      }
    })();
  </script>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <script>
    var API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

    var form = document.getElementById("contact-form");
    var submitBtn = document.getElementById("submit-btn");
    var btnText = document.getElementById("btn-text");
    var btnIcon = document.getElementById("btn-icon");
    var btnSpinner = document.getElementById("btn-spinner");
    var statusMsg = document.getElementById("status-message");
    var turnstileError = document.getElementById("turnstile-error");

    window.onTurnstileSuccess = function () {
      turnstileError.style.display = "none";
      submitBtn.disabled = false;
      submitBtn.style.opacity = "1";
    };

    window.onTurnstileExpired = function () {
      submitBtn.disabled = true;
      submitBtn.style.opacity = "0.5";
    };

    window.onTurnstileError = function () {
      submitBtn.disabled = true;
      submitBtn.style.opacity = "0.5";
    };

    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      var tokenInput = document.querySelector('[name="cf-turnstile-response"]');
      var token = tokenInput ? tokenInput.value : null;

      if (!token) {
        turnstileError.style.display = "";
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = "Sending...";
      btnIcon.style.display = "none";
      btnSpinner.style.display = "";
      statusMsg.style.display = "none";

      var data = {
        name: document.getElementById("name").value.trim(),
        email: document.getElementById("email").value.trim(),
        phone: document.getElementById("phone").value.trim() || undefined,
        subject: document.getElementById("subject").value.trim(),
        message: document.getElementById("message").value.trim(),
        cfTurnstileResponse: token,
      };

      try {
        var res = await fetch(API_URL + "/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (!res.ok) {
          var err = await res.json().catch(function () { return {}; });
          throw new Error(err.error || "Something went wrong");
        }

        statusMsg.style.display = "";
        statusMsg.style.color = "var(--accent)";
        statusMsg.textContent = "Message sent! I'll get back to you soon.";
        form.reset();

        var turnstileWidget = document.querySelector(".cf-turnstile");
        if (turnstileWidget && window.turnstile) {
          turnstile.reset(turnstileWidget);
        }
        submitBtn.disabled = true;
        submitBtn.style.opacity = "0.5";
      } catch (err) {
        statusMsg.style.display = "";
        statusMsg.style.color = "#E07060";
        statusMsg.textContent = err.message || "Failed to send message. Try again later.";

        var turnstileWidget = document.querySelector(".cf-turnstile");
        if (turnstileWidget && window.turnstile) {
          turnstile.reset(turnstileWidget);
        }
        submitBtn.disabled = true;
        submitBtn.style.opacity = "0.5";
      } finally {
        btnText.textContent = "Send message";
        btnIcon.style.display = "";
        btnSpinner.style.display = "none";
      }
    });
  </script>
</Layout>
