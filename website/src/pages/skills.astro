---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const skills = await getCollection("skills");
skills.sort((a, b) => a.data.order - b.data.order);

const renderedSkills = await Promise.all(
  skills.map(async (skill) => {
    const { Content } = await render(skill);
    return { ...skill, Content };
  })
);
---

<Layout title="Skills — Amr Yasser Loksha">
  <div class="mx-auto max-w-4xl">
    <div class="flex items-center gap-3">
      <span class="font-hand text-sm" style="color: var(--accent);">Skills</span>
      <span class="h-px flex-1" style="background: var(--border);"></span>
    </div>

    <h1 class="mt-6 text-3xl font-light tracking-tight sm:text-4xl md:text-5xl" style="color: var(--text);">
      Skills & expertise
    </h1>
    <p class="mt-3 max-w-2xl leading-relaxed text-secondary">
      Development, security, and community — the crafts I bring to every project.
    </p>

    <!-- Hand-drawn wavy line -->
    <svg xmlns="http://www.w3.org/2000/svg" width="160" height="16" viewBox="0 0 160 16" fill="none" class="mt-6" style="color: var(--warm);">
      <path d="M2 10 C 15 2, 30 14, 45 8 C 60 2, 75 14, 90 8 C 105 2, 120 14, 135 8 C 150 2, 158 12, 158 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.35"/>
    </svg>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {renderedSkills.map((skill) => (
        <div class="group rounded-2xl p-7 transition-all duration-300" style="border: 1px solid var(--border); background: var(--surface);" onmouseover="this.style.borderColor='color-mix(in srgb, var(--accent) 30%, transparent)'; this.style.background='var(--surface-2)'" onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--surface)'">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-all duration-300" style="border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent); background: color-mix(in srgb, var(--accent) 5%, transparent); color: var(--accent);" onmouseover="this.style.background='color-mix(in srgb, var(--accent) 10%, transparent)'; this.style.borderColor='color-mix(in srgb, var(--accent) 40%, transparent)'" onmouseout="this.style.background='color-mix(in srgb, var(--accent) 5%, transparent)'; this.style.borderColor='color-mix(in srgb, var(--accent) 20%, transparent)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {skill.data.icon === "code" && <>
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </>}
              {skill.data.icon === "shield" && <>
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </>}
              {skill.data.icon === "users" && <>
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </>}
            </svg>
          </div>
          <h2 class="text-lg font-semibold" style="color: var(--text);">{skill.data.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-secondary">
            {skill.data.description}
          </p>
          <div class="mt-4 text-xs leading-relaxed" style="color: var(--text-muted); [&>p]:mt-2 [&>p:first-child]:mt-0">
            <skill.Content />
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16" style="border-top: 1px solid var(--border);">
      <div class="pt-8 flex items-center justify-between">
        <a href="/" class="group inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 cursor-pointer" style="color: var(--accent);" onmouseover="this.style.color='var(--accent-soft)'" onmouseout="this.style.color='var(--accent)'">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back home
        </a>
        <span class="font-hand text-sm" style="color: var(--text-muted);">what I do</span>
      </div>
    </div>
  </div>
</Layout>
