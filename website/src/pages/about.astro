---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const aboutEntry = (await getCollection("about"))[0];
if (!aboutEntry) throw new Error("About entry not found");
const { Content } = await render(aboutEntry);
---

<Layout title="About — Amr Yasser Loksha">
  <article class="mx-auto max-w-3xl">
    <div class="flex items-center gap-3">
      <span class="font-hand text-sm" style="color: var(--accent);">About</span>
      <span class="h-px flex-1" style="background: var(--border);"></span>
    </div>

    <h1 class="mt-6 text-3xl font-light tracking-tight sm:text-4xl md:text-5xl" style="color: var(--text);">
      {aboutEntry.data.title}
    </h1>
    <p class="mt-3 font-hand text-lg" style="color: var(--accent-soft);">
      {aboutEntry.data.subtitle}
    </p>

    <!-- Photo with hand-drawn frame -->
    <div class="mt-10 relative inline-block">
      <img src="/images/amr-loksha.jpeg" alt="Amr Yasser Loksha" class="h-40 w-40 rounded-2xl object-cover" style="border: 1px solid var(--border); filter: grayscale(0.3); transition: filter 0.4s ease;" onmouseover="this.style.filter='grayscale(0)'" onmouseout="this.style.filter='grayscale(0.3)'" />
      <svg xmlns="http://www.w3.org/2000/svg" width="140" height="24" viewBox="0 0 140 24" fill="none" class="mt-2" style="color: var(--accent);">
        <path d="M4 18 C 15 6, 30 22, 45 14 C 60 6, 75 22, 90 14 C 105 6, 120 20, 135 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4"/>
        <circle cx="8" cy="8" r="1.5" fill="currentColor" opacity="0.3"/>
        <circle cx="132" cy="10" r="1.5" fill="currentColor" opacity="0.3"/>
        <circle cx="70" cy="4" r="1" fill="currentColor" opacity="0.2"/>
      </svg>
    </div>

    <div class="mt-10 leading-relaxed text-secondary [&>p]:mt-5 [&>p:first-child]:mt-0 [&>p]:leading-[1.8]">
      <Content />
    </div>

    <!-- Hand-drawn signature line -->
    <div class="mt-16" style="border-top: 1px solid var(--border);">
      <div class="pt-8 flex items-center justify-between">
        <a href="/" class="group inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 cursor-pointer" style="color: var(--accent);" onmouseover="this.style.color='var(--accent-soft)'" onmouseout="this.style.color='var(--accent)'">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back home
        </a>
        <span class="font-hand text-sm" style="color: var(--text-muted);">amrloksha151</span>
      </div>
    </div>
  </article>
</Layout>
