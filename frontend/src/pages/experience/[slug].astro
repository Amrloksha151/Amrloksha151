---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const experiences = await getCollection('experiences');
  return experiences.map(exp => ({
    params: { slug: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);
---

<Layout 
  title={`${exp.data.role} at ${exp.data.company} | Experience`}
  description={exp.data.description}
>
  <SectionWrapper id="experience-detail" class="pt-32">
    <div class="mb-8">
      <a href="/experience" class="mono terminal-prompt text-sm text-text-muted hover:text-accent-green transition-colors">cd ../</a>
    </div>

    <article class="card p-8 md:p-12">
      <header class="mb-10 border-b border-white/10 pb-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="badge">{exp.data.type}</span>
          <span class="mono text-sm text-accent-green">{exp.data.startDate} — {exp.data.endDate || 'Present'}</span>
        </div>
        
        <h1 class="section-title text-3xl md:text-5xl mb-2">{exp.data.role}</h1>
        <h2 class="text-xl md:text-2xl text-accent-blue font-mono mb-6">@ {exp.data.company}</h2>
        
        <p class="text-lg text-text-secondary max-w-3xl leading-relaxed">{exp.data.description}</p>
      </header>

      <div class="prose prose-invert prose-green max-w-none">
        <Content />
      </div>
    </article>
  </SectionWrapper>
</Layout>

<style is:global>
  .prose { color: var(--text-primary); }
  .prose h2 { font-family: var(--font-heading); color: var(--text-primary); margin-top: 2.5em; margin-bottom: 1em; padding-bottom: 0.5em; border-bottom: 1px solid var(--border-color); }
  .prose h3 { font-family: var(--font-heading); color: var(--text-primary); margin-top: 2em; }
  .prose p { color: var(--text-secondary); line-height: 1.8; }
  .prose ul, .prose ol { color: var(--text-secondary); }
  .prose li::marker { color: var(--accent-green); }
</style>
