---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import { getCollection } from 'astro:content';

const allExperiences = (await getCollection('experiences'))
  .sort((a, b) => b.data.startDate.localeCompare(a.data.startDate));
---

<Layout
  title="Experience"
  description="Professional experience in web security, bug bounty, and web development."
>
  <SectionWrapper id="experience-page" class="pt-32">
    <div class="mb-12">
      <p class="mono terminal-prompt text-sm text-text-muted mb-2">cat /var/log/career.log</p>
      <h1 class="section-title">Experience</h1>
      <p class="section-subtitle">A timeline of my professional journey in security and development.</p>
    </div>

    <div class="timeline mt-12">
      {allExperiences.map((exp) => (
        <div class="timeline-item animate-fade-up">
          <div class="card p-6 md:p-8 ml-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
              <div>
                <h2 class="text-2xl font-bold text-text-primary mb-1">{exp.data.role}</h2>
                <div class="text-accent-blue font-mono text-sm">{exp.data.company}</div>
              </div>
              <div class="flex flex-col md:items-end">
                <span class="badge mb-2">{exp.data.type}</span>
                <span class="mono text-xs text-text-muted">{exp.data.startDate} — {exp.data.endDate || 'Present'}</span>
              </div>
            </div>
            
            <p class="text-text-secondary mt-4 mb-6 leading-relaxed">
              {exp.data.description}
            </p>

            <a href={`/experience/${exp.id}`} class="text-accent-green font-mono text-sm hover:text-white hover:bg-accent-green px-3 py-1 rounded transition-all inline-flex items-center gap-2">
              Read Details <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </SectionWrapper>
</Layout>
