---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const featured = allProjects.filter(p => p.data.featured);
const rest = allProjects.filter(p => !p.data.featured);
const sorted = [...featured, ...rest];
---

<Layout
  title="Projects"
  description="Security research projects, tools, and web development work by Amr Loksha. HTTP smuggling, cache poisoning, Cloudflare Workers, and more."
>
  <SectionWrapper id="projects-page" class="projects-page">
    <div class="page-header">
      <p class="page-breadcrumb mono terminal-prompt">ls -la ~/projects</p>
      <h1 class="section-title">Projects</h1>
      <p class="section-subtitle">
        Security research, open-source tools, and web development work.
        <br />
        <span class="mono" style="font-size: 0.85rem; color: var(--text-muted);">
          {sorted.length} projects found
        </span>
      </p>
    </div>

    <!-- Filter buttons -->
    <div class="filter-bar" id="filter-bar" role="group" aria-label="Filter projects">
      <button id="filter-all" class="filter-btn active" data-filter="all">All</button>
      <button id="filter-active" class="filter-btn" data-filter="active">Active</button>
      <button id="filter-completed" class="filter-btn" data-filter="completed">Completed</button>
      <button id="filter-featured" class="filter-btn" data-filter="featured">Featured</button>
    </div>

    <div class="projects-grid" id="projects-grid">
      {sorted.map((project) => (
        <a
          href={`/projects/${project.id}`}
          id={`project-card-${project.id}`}
          class="card project-card"
          data-status={project.data.status}
          data-featured={project.data.featured ? 'featured' : ''}
        >
          <div class="project-inner">
            {project.data.featured && (
              <div class="featured-label mono">★ featured</div>
            )}

            <div class="project-meta">
              <div class="project-status-badge">
                <span class={`status-dot ${project.data.status === 'active' ? 'dot-active' : project.data.status === 'completed' ? 'dot-completed' : 'dot-archived'}`}></span>
                <span class="mono" style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase;">{project.data.status}</span>
              </div>
              <span class="mono" style="font-size: 0.75rem; color: var(--text-muted);">{project.data.date}</span>
            </div>

            <h2 class="project-title">{project.data.title}</h2>
            <p class="project-desc">{project.data.description}</p>

            <div class="project-tags">
              {project.data.tags.slice(0, 5).map(tag => (
                <span class="badge">{tag}</span>
              ))}
            </div>

            <div class="project-links">
              <span class="read-more">Read more →</span>
              <div class="ext-links">
                {project.data.github && <span class="ext-link mono">GitHub ↗</span>}
                {project.data.demo && <span class="ext-link mono">Demo ↗</span>}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </SectionWrapper>
</Layout>

<style>
  .projects-page {
    padding-top: 7rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-breadcrumb {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    padding: 0.4rem 1rem;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: rgba(0, 255, 136, 0.08);
    color: var(--accent-green);
    border-color: var(--border-hover);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: block;
    text-decoration: none;
    padding: 1.75rem;
    position: relative;
  }

  .project-card.hidden {
    display: none;
  }

  .project-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.875rem;
  }

  .featured-label {
    font-size: 0.7rem;
    color: var(--accent-green);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-status-badge {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .dot-active {
    background: var(--accent-green);
    box-shadow: 0 0 6px var(--accent-green);
    animation: pulse 2s ease-in-out infinite;
  }
  .dot-completed { background: var(--accent-blue); }
  .dot-archived { background: var(--text-muted); }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .project-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .project-card:hover .project-title {
    color: var(--accent-green);
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .project-links {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.875rem;
    border-top: 1px solid var(--border-color);
    margin-top: 0.25rem;
  }

  .read-more {
    font-size: 0.8rem;
    color: var(--accent-green);
    font-family: var(--font-mono);
    transition: letter-spacing var(--transition-fast);
  }

  .project-card:hover .read-more {
    letter-spacing: 0.05em;
  }

  .ext-links {
    display: flex;
    gap: 0.75rem;
  }

  .ext-link {
    font-size: 0.7rem;
    color: var(--text-muted);
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .project-card:hover .ext-link {
    color: var(--accent-blue);
    border-color: rgba(0, 212, 255, 0.3);
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      projectCards.forEach(card => {
        const el = card as HTMLElement;
        if (filter === 'all') {
          el.classList.remove('hidden');
        } else if (filter === 'featured') {
          el.dataset.featured === 'featured'
            ? el.classList.remove('hidden')
            : el.classList.add('hidden');
        } else {
          el.dataset.status === filter
            ? el.classList.remove('hidden')
            : el.classList.add('hidden');
        }
      });
    });
  });
</script>
